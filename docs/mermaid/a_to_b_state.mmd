flowchart TD
    subgraph Client
        direction TB
        C_loop([loop]) -->|"sent = ping"| C_loop
    end

    subgraph Relay
        direction TB
        subgraph R_relay["relay"]
            direction TB
            R_wait([wait])
        end
        R_entry(( ))
        R_entry -->|"recv msg"| R_wait
        R_wait -->|"send msg"| R_entry
    end

    subgraph Server
        direction TB
        S_idle([idle]) -->|"received = ping"| S_idle
    end

    C_loop -. send ping .-> R_relay
    R_wait -. send ping .-> S_idle
