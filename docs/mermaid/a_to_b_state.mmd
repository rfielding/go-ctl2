flowchart TD
    subgraph Client
        direction TB
        C_start([start]) -->|"sent = ping<br/>become done"| C_done([done])
    end

    subgraph Relay
        direction TB
        R_relay([relay]) -->|"recv msg<br/>become relay__wait_0"| R_wait0([relay__wait_0])
        R_wait0 -->|"send msg<br/>become relay"| R_relay
    end

    subgraph Server
        direction TB
        S_idle([idle]) -->|"received = ping<br/>become accepted"| S_accepted([accepted])
    end

    C_done -. send ping .-> R_relay
    R_wait0 -. send ping .-> S_idle
